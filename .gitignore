# --- Data caches (derived; rebuildable, often large) ---
*.parquet

# Phase 3.4 served SQLite DB the dataset-analyze skill builds at
# ${CLAUDE_PROJECT_DIR}/.magpie/ for the read-only mcp-sqlite server. Derived +
# rebuildable, and it may hold PII-derived rows -- never commit it. (Normally
# built in the operator's data project, not here; defensive for dev/testing.)
.magpie/

# --- Research-workflow scratch ---
.research-workflow/

# ============================================================
# NEVER commit the Simpsonville corpus (PII)
# ------------------------------------------------------------
# The real Flock/Simpsonville FOIA corpus contains personal data
# (names, DOBs, A-numbers, plate context). It lives OUTSIDE this
# repo (the operator's Downloads) and is referenced for golden
# tests only via an env var (see Task 11.2). Never copy real data
# into the tree. These rules are defensive belt-and-suspenders:
corpus/private/
*-Audit-logs/
*-Audit.csv
*-Network-Audit.csv
**/*[Ss]impsonville*[Aa]udit*
pii_*_exhibit.csv
pretext_exhibit.csv
immigration_exhibit.csv
# ============================================================

# --- Cross-model-review plugin (local session / hook state) ---
.claude/*.local.md

# --- Codex review outputs (tools/codex-review.ps1; ephemeral, may quote PII-derived findings) ---
.codex-review/

# --- Session handoffs (local-only: internal process notes + local paths; public repo) ---
docs/handoffs/

# --- Phase 13a entity-graph: nomenklatura resolver scratch DB ---
# The per-investigation resolver SQLite lives under a gitignored scratch dir
# (NOMENKLATURA_DB_URL). This is a defensive rule against the library's default
# ./nomenklatura.db fallback path ever leaking into the tree.
nomenklatura.db
*.nomenklatura.db

# --- Local preview/dev-server config (Claude preview) ---
.claude/launch.json

# --- OS / editor noise ---
.DS_Store
Thumbs.db
