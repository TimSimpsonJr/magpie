# Magpie Layer-2 infra secrets -- TEMPLATE.
#
# Copy this file to infra/.env (gitignored) and set a strong, unique password
# BEFORE bringing the graph profile up:
#
#     cp infra/.env.example infra/.env
#     # edit infra/.env, then:
#     docker compose -f infra/docker-compose.yml --env-file infra/.env --profile graph up -d
#
# NEO4J_AUTH is derived as neo4j/<NEO4J_PASSWORD>. The neo4j driver authenticates
# as user "neo4j" with this password (bolt://127.0.0.1:7687).
NEO4J_PASSWORD=change-me-to-a-strong-random-password
